# ═══════════════════════════════════════════════════════════════
# WebScrapy AI Platform — Variáveis de Ambiente
# Copie este arquivo para .env e configure os valores
# NUNCA commite o .env com secrets reais
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=WebScrapy AI Platform
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://webscrapy:webscrapy123@localhost:5432/webscrapy
POSTGRES_PASSWORD=webscrapy123

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── NVIDIA NIM API ───────────────────────────────────────────
# Obtenha sua chave em: https://build.nvidia.com/
# OBRIGATÓRIO para funcionalidade de IA
NVIDIA_API_KEY=
# Alias aceito pelo backend, mas prefira NVIDIA_API_KEY
NVIDIA_API=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── JWT Authentication ───────────────────────────────────────
# Gere com: openssl rand -hex 32
SECRET_KEY=TROQUE_ESTA_CHAVE_EM_PRODUCAO_GERE_COM_OPENSSL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO (S3-compatible) ────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=webscrapy-results
MINIO_SECURE=false

# ── APIs Externas Opcionais ──────────────────────────────────
# Configure para usar APIs antes de scraping (recomendado)

# Notícias — https://newsapi.org/ (gratuito até 100 req/dia)
NEWSAPI_KEY=

# Notícias — https://gnews.io/ (gratuito até 100 req/dia)
GNEWS_KEY=

# Passagens aéreas — https://aviationstack.com/ (gratuito até 100 req/mês)
AVIATIONSTACK_KEY=

# Passagens aéreas — https://developers.amadeus.com/ (gratuito)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Leads/Emails — https://hunter.io/ (gratuito até 25 buscas/mês)
HUNTER_IO_KEY=

# Vagas — Arbeitnow é gratuito e sem chave!
# Vagas — The Muse API é gratuita e sem chave!
