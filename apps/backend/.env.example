# Copy this file to .env and fill in values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://webscrapy:webscrapy@postgres:5432/webscrapy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── NVIDIA AI ─────────────────────────────────────────────────────────────────
# Get your key from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alias aceito pelo backend, mas prefira NVIDIA_API_KEY
NVIDIA_API=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=webscrapy-results

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
